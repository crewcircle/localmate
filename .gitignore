# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.pyi
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node (dashboard has its own .gitignore; this catches stray top-level)
node_modules/

# Build artifacts
.next/
dist/
build/

# Env files — never commit secrets. See .env.example for required values.
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Vercel — only project.json (non-secret IDs) is committed; auth.json excluded by this rule
dashboard/.vercel/*
!dashboard/.vercel/project.json

# Logs
*.log